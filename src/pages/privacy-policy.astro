---
import BaseLayout from "../layouts/BaseLayout.astro";
import "../styles/static-page.css";
---

<BaseLayout
  title="Privacy Policy | GovtJobsNotice"
  description="Privacy Policy of GovtJobsNotice"
>

<main class="static-page">

  <section class="static-box">

    <h1 class="static-title">
      Privacy Policy
    </h1>

    <div class="static-content">

      <p>

        GovtJobsNotice values your privacy.
        This Privacy Policy explains how
        information may be collected and used
        while using our website.

      </p>

      <h2>
        Cookies
      </h2>

      <p>

        Our website may use cookies
        to improve user experience,
        analytics and advertising services.

      </p>

      <h2>
        Third Party Services
      </h2>

      <p>

        We may use third-party services such as
        Google Analytics and Google AdSense
        which may collect anonymous usage data.

      </p>

      <h2>
        External Links
      </h2>

      <p>

        Our website may contain links
        to external official websites.
        We are not responsible for the privacy
        practices of those websites.

      </p>

    </div>

  </section>

</main>

</BaseLayout>