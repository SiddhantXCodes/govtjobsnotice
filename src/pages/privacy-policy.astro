---
import BaseLayout from "../layouts/BaseLayout.astro";

import { buildStaticSeo } from "../lib/seo/buildStaticSeo";

const seo = buildStaticSeo({
  title: "Privacy Policy | GovtJobsNotice",

  description:
    "Read the Privacy Policy of GovtJobsNotice regarding cookies, Google Analytics, Google AdSense, third-party services and website usage.",

  slug: "privacy-policy",

  type: "WebPage",
});
---

<BaseLayout {...seo}>
  <main class="static-page">
    <section class="static-box">
      <h1 class="static-title">Privacy Policy</h1>

      <div class="static-content">
        <p>
          GovtJobsNotice values your privacy. This Privacy Policy explains how
          information may be collected, used and protected while using our
          website.
        </p>

        <p>
          By accessing and using GovtJobsNotice, you agree to the terms
          mentioned in this Privacy Policy.
        </p>

        <h2>Information Collection</h2>

        <p>
          We may collect limited non-personal information such as browser type,
          device information, pages visited and usage statistics to improve
          website performance and user experience.
        </p>

        <h2>Cookies Policy</h2>

        <p>
          GovtJobsNotice may use cookies to improve user experience, remember
          preferences, analyze traffic and support advertising services.
        </p>

        <p>
          Users can disable cookies through their browser settings if preferred.
        </p>

        <h2>Google Analytics</h2>

        <p>
          We may use Google Analytics to understand website traffic, visitor
          behavior and performance metrics.
        </p>

        <p>
          Google Analytics may collect anonymous usage information according to
          Google's policies.
        </p>
        <h2>Third-Party Services</h2>

        <p>
          GovtJobsNotice may use third-party services such as Google Analytics
          and Google AdSense to analyze traffic and display advertisements.
          These services may collect information in accordance with their own
          privacy policies.
        </p>
        <h2>Google AdSense</h2>

        <p>
          GovtJobsNotice may display advertisements provided by Google AdSense
          and other advertising partners.
        </p>

        <p>
          Third-party vendors, including Google, may use cookies to serve ads
          based on users' previous visits to this website and other websites.
        </p>

        <h2>External Links</h2>

        <p>
          Our website may contain links to official government websites and
          other external platforms.
        </p>

        <p>
          We are not responsible for the privacy practices, content or policies
          of external websites.
        </p>

        <h2>Data Security</h2>

        <p>
          We try to maintain reasonable security measures to protect website
          integrity and user experience. However, no internet-based platform can
          guarantee complete security.
        </p>

        <h2>Policy Updates</h2>

        <p>
          GovtJobsNotice may update this Privacy Policy at any time without
          prior notice.
        </p>

        <p>
          Users are advised to review this page periodically for the latest
          updates and policy changes.
        </p>

        <h2>Contact</h2>

        <p>
          If you have any questions regarding this Privacy Policy, you may
          contact us through the official contact page available on
          GovtJobsNotice.
        </p>
      </div>
    </section>
  </main>
</BaseLayout>
