---
import BaseLayout from "../layouts/BaseLayout.astro";


const schema = {
  "@context": "https://schema.org",

  "@type": "WebPage",

  name: "Disclaimer - GovtJobsNotice",

  url: "https://govtjobsnotice.com/disclaimer",

  description:
    "Official disclaimer page of GovtJobsNotice regarding information accuracy, external links and website usage.",
};
---

<BaseLayout
  title="Disclaimer | GovtJobsNotice"

  description="Read the official disclaimer of GovtJobsNotice regarding government job notifications, Sarkari Result updates, recruitment information and external website references."

  canonical="https://govtjobsnotice.com/disclaimer"

  keywords="govtjobsnotice disclaimer, govt jobs notice disclaimer, government jobs website disclaimer, sarkari result disclaimer, recruitment information disclaimer"

  schema={schema}
>

<main class="static-page">

  <section class="static-box">

    <h1 class="static-title">
      Disclaimer
    </h1>

    <div class="static-content">

      <p>

        GovtJobsNotice is an independent educational
        and informational platform created to provide
        latest government job notifications,
        Sarkari Result updates, admit cards,
        answer keys, syllabus and recruitment information.

      </p>

      <p>

        GovtJobsNotice is not a government website
        and is not affiliated, associated or connected
        with any government department,
        organization, commission or recruitment authority.

      </p>

      <h2>
        Information Accuracy
      </h2>

      <p>

        We make every reasonable effort
        to provide accurate, updated and reliable information.

      </p>

      <p>

        However, users are strongly advised
        to verify all details including eligibility,
        important dates, application process,
        fees, admit cards, results and notifications
        from the official website and official notification
        before taking any action.

      </p>

      <h2>
        No Official Representation
      </h2>

      <p>

        GovtJobsNotice does not claim
        to represent any government authority
        or official recruitment agency.

      </p>

      <p>

        All trademarks, logos and organization names
        mentioned on this website belong
        to their respective owners.

      </p>

      <h2>
        External Links Disclaimer
      </h2>

      <p>

        Our website may contain links
        to official government websites
        and third-party websites
        for user convenience and reference.

      </p>

      <p>

        GovtJobsNotice is not responsible
        for the content, policies,
        availability or accuracy
        of external websites.

      </p>

      <h2>
        Limitation of Liability
      </h2>

      <p>

        GovtJobsNotice will not be responsible
        for any loss, damage or inconvenience
        arising from the use of information
        available on this website.

      </p>

      <p>

        Users are advised to independently verify
        all information before making decisions
        related to applications, examinations
        or recruitment processes.

      </p>

      <h2>
        Content Updates
      </h2>

      <p>

        Information on GovtJobsNotice
        may be updated, modified or removed
        at any time without prior notice.

      </p>

      <h2>
        Contact
      </h2>

      <p>

        For any queries related to this disclaimer,
        users may contact us through
        the official contact page available on GovtJobsNotice.

      </p>

    </div>

  </section>

</main>

</BaseLayout>