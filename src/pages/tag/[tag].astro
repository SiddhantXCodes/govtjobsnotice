---
import BaseLayout from "../../layouts/BaseLayout.astro";

import Breadcrumbs from "../../components/Breadcrumbs.astro";

import {
  getAllPosts,
  getPostsByTag,
} from "../../lib/repositories/postRepository";
import { buildArchiveSeo } from "../../lib/seo/buildArchiveSeo";

export async function getStaticPaths() {
  const posts = await getAllPosts();

  const tags = [
    ...new Set(
      posts.flatMap((post: any) => {
        if (!post.tags || !Array.isArray(post.tags)) {
          return [];
        }

        return post.tags.map((tag: string) =>
          tag.trim().toLowerCase().replace(/\s+/g, "-"),
        );
      }),
    ),
  ];

  return tags.map((tag) => ({
    params: { tag },
  }));
}
const { tag } = Astro.params;

const posts = await getPostsByTag(tag || "", 100);

const tagTitle = tag
  ?.replaceAll("-", " ")
  .replace(/\b\w/g, (c: string) => c.toUpperCase());

  const seo = buildArchiveSeo({
  title:
    `${tagTitle} Jobs | GovtJobsNotice`,

  description:
    `${tagTitle} government jobs, admit cards, results, answer keys and latest recruitment updates`,

  canonical:
    `/tag/${tag}/`,
});
---

<BaseLayout {...seo}>
  <main class="page-container">
    <!-- HEADER -->

    <section class="page-header common-box">
      <Breadcrumbs
        items={[
          {
            label: `${tagTitle} Jobs`,
          },
        ]}
      />

      <h1 class="page-title">
        {tagTitle} Jobs
      </h1>

      <div class="page-count">
        Total Posts :
        {posts.length}
      </div>

      <p class="page-description">
        Get latest {tagTitle.toLowerCase()} government jobs, recruitment notifications,
        admit cards, results, answer keys, exam dates and official updates from various
        central and state government departments.
      </p>
    </section>

    <!-- TABLE -->

    <section class="table-wrap">
      <table class="common-table">
        <thead>
          <tr>
            <th> Post Name </th>

            <th> Category </th>

            <th> Updated Date </th>
          </tr>
        </thead>

        <tbody>
          {
            posts.map((post) => (
              <tr>
                <td>
                  <a href={`/${post.slug}/`} class="table-link">
                    {post.title}
                  </a>
                </td>

                <td>
                  {post.category
                    ?.replaceAll("-", " ")
                    .replace(/\b\w/g, (c: any) => c.toUpperCase())}
                </td>

                <td>
                  {post.published_at
                    ? new Date(post.published_at).toLocaleDateString("en-IN", {
                        day: "numeric",
                        month: "short",
                        year: "numeric",
                      })
                    : "-"}
                </td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </section>

    <!-- SEO CONTENT -->

    <section class="seo-box common-box">
      <h2>
        Latest {tagTitle} Government Jobs
      </h2>

      <p>
        GovtJobsNotice provides latest
        {tagTitle.toLowerCase()} government jobs, recruitment notifications, admit
        cards, results, answer keys, syllabus and official announcements.
      </p>

      <p>
        Candidates can check exam dates, application forms, eligibility, results
        and official notifications for SSC, Railway, Banking, UPSC, Defence, PSU
        and State Government recruitments.
      </p>
    </section>
  </main>
</BaseLayout>
