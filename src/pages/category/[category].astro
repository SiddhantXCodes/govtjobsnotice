---
import BaseLayout
  from "../../layouts/BaseLayout.astro";

import Breadcrumbs
  from "../../components/Breadcrumbs.astro";

import {
  getPostsByCategory
} from "../../lib/repositories/postRepository";
const getDate = (
  post: any,
  key: string
) => {

  return (
    post?.important_dates?.[key] ||
    null
  );

};

export async function getStaticPaths() {

  const categories = [

    "latest-jobs",
    "results",
    "admit-card",
    "answer-key",
    "admission",
    "syllabus",

  ];

  return categories.map((category)=>({

    params:{
      category
    }

  }));

}

const { category } =
  Astro.params;

const posts =
  await getPostsByCategory(
    category,
    100
  );

const categoryTitle =
  category
    ?.replaceAll("-"," ")
    .replace(
      /\b\w/g,
      (c)=>c.toUpperCase()
    );

/* COLUMN LOGIC */

const getColumns = ()=>{

  switch(category){

    case "latest-jobs":

      return [
        "Post Name",
        "Application Start",
        "Last Date"
      ];

    case "results":

      return [
        "Result Name",
        "Post Date",
        "Result Date"
      ];

    case "admit-card":

      return [
        "Admit Card",
        "Exam Date",
        "Admit Card Date"
      ];

    case "answer-key":

      return [
        "Answer Key",
        "Exam Date",
        "Answer Key Date"
      ];

    case "admission":

      return [
        "Admission",
        "Application Start",
        "Last Date"
      ];

    case "syllabus":

      return [
        "Syllabus",
        "Post Date",
        "Updated Date"
      ];

    default:

      return [
        "Title",
        "Date",
        "Status"
      ];

  }

};

const columns =
  getColumns();

---

<BaseLayout
  title={`${categoryTitle} | GovtJobsNotice`}
  description={`${categoryTitle} updates, notifications, admit cards, results and latest information`}
>

<main class="page-container">

  <!-- HEADER -->

  <section class="page-header common-box">

    <Breadcrumbs
      items={[
        {
          label:categoryTitle
        }
      ]}
    />

    <h1 class="page-title">

      {categoryTitle}

    </h1>

    <div class="page-count">

      Total Posts :
      {posts.length}

    </div>

    <p class="page-description">

      Get latest {categoryTitle.toLowerCase()} updates,
      notifications,
      exam dates,
      admit cards,
      answer keys,
      admissions and recruitment information
      from various government organizations.

    </p>

  </section>

  <!-- TABLE -->

  <section class="table-wrap">

    <table class="common-table">

      <thead>

        <tr>

          {
            columns.map((column)=>(

              <th>

                {column}

              </th>

            ))
          }

        </tr>

      </thead>

      <tbody>

        {
          posts.map((post)=>(

            <tr>

              <!-- TITLE -->

              <td>

                <a
                  href={`/${post.slug}/`}
                  class="table-link"
                >

                  {post.title}

                </a>

              </td>

              <!-- LATEST JOBS -->

              {
                category === "latest-jobs" && (

                  <>
                    <td>
                      { getDate(
                      post,
                      "application_start"
                    )
                      ?.display_text || "-"
                      }

                    </td>

                    <td>

                      {
                        getDate(
                        post,
                        "application_end"
                      )
                        ?.display_text || "-"
                      }

                    </td>
                  </>

                )
              }

              <!-- RESULTS -->

              {
                category === "results" && (

                  <>
                    <td>

                      {
                      post.published_at
                            ? new Date(post.published_at)
                                .toLocaleDateString(
                                  "en-IN",
                                  {
                                    day:"numeric",
                                    month:"short",
                                    year:"numeric"
                                  }
                                )
                            : "-"
                      }

                    </td>

                    <td>

                      {
                getDate(
                      post,
                      "result_date"
                    )
                      ?.display_text || "-"
                      }

                    </td>
                  </>

                )
              }

              <!-- ADMIT CARD -->

              {
                category === "admit-card" && (

                  <>
                    <td>

                      {
              getDate(
                    post,
                    "cbt_exam_date"
                  )
                    ?.display_text || "-"
                      }

                    </td>

                    <td>

                      {
              getDate(
                          post,
                          "admit_card_release"
                        )
                          ?.display_text || "-"
                      }

                    </td>
                  </>

                )
              }

              <!-- ANSWER KEY -->

              {
                category === "answer-key" && (

                  <>
                    <td>

                      {
                  getDate(
                      post,
                      "cbt_exam_date"
                    )
                      ?.display_text || "-"
                      }

                    </td>

                    <td>

                      {
                   getDate(
                          post,
                          "answer_key_release"
                        )
                          ?.display_text || "-"
                      }

                    </td>
                  </>

                )
              }

              <!-- ADMISSION -->

              {
                category === "admission" && (

                  <>
                    <td>
                      {
                    getDate(
                      post,
                      "application_start"
                              )
                              ?.display_text || "-"
                      }
                    </td>
                    <td>
                      {
                   getDate(
                      post, 
                    "application_end"
                    )
                      ?.display_text || "-"
                      }

                    </td>
                  </>

                )
              }

            

            </tr>

          ))
        }

      </tbody>

    </table>

  </section>

  <!-- SEO -->

  <section class="seo-box common-box">

    <h2>

      Latest {categoryTitle} Updates

    </h2>

    <p>

      GovtJobsNotice provides latest
      {categoryTitle.toLowerCase()} updates,
      recruitment notifications,
      admit cards,
      results,
      answer keys,
      syllabus and official announcements.

    </p>

    <p>

      Candidates can check exam dates,
      application forms,
      eligibility,
      results and official notifications
      for SSC,
      Railway,
      Banking,
      UPSC,
      Defence,
      PSU and State Government recruitments.

    </p>

  </section>

</main>

</BaseLayout>