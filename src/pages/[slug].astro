---
import BaseLayout from "../layouts/BaseLayout.astro";

import { getAllPosts, getPostBySlug } from "../lib/repositories/postRepository";

import Breadcrumbs from "../components/Breadcrumbs.astro";
import PostSuggestions from "../components/PostSuggestions.astro";
import SocialLinks from "../components/SocialLinks.astro";

import SectionRenderer from "../components/post/SectionRenderer.astro";

/* =========================================
   STATIC PATHS
========================================= */

export async function getStaticPaths() {
  const posts = await getAllPosts();

  return posts.map((post) => ({
    params: {
      slug: post.slug,
    },
  }));
}

/* =========================================
   POST
========================================= */

const { slug } = Astro.params;

const post = await getPostBySlug(slug);

if (!post) {
  return Astro.redirect("/404");
}

/* =========================================
   DATE FORMAT
========================================= */

const formatDate = (date: string) => {
  if (!date) {
    return "";
  }

  return new Date(date).toLocaleString("en-IN", {
    day: "numeric",
    month: "long",
    year: "numeric",
    hour: "numeric",
    minute: "2-digit",
    hour12: true,
  });
};

/* =========================================
   SEO
========================================= */

const seoTitle = post?.overview?.seo?.title || post?.title;

const seoDescription = post?.overview?.seo?.description || "";

const postTitle = post?.title || "GovtJobsNotice";

const shortName = post?.feed_title || "GovtJobsNotice";

/* =========================================
   IMPORTANT DATES
========================================= */

const importantDates = Object.values(post?.important_dates || {});

/* =========================================
   SECTIONS
========================================= */
const applicationFee = post?.application_fee || null;

const ageLimit = post?.age_limit || null;

const importantLinks = post?.important_links || null;

const normalSections = post?.sections || [];
const schema = {
  "@context": "https://schema.org",

  "@type": "NewsArticle",

  headline: seoTitle,

  description: seoDescription,

  datePublished: post?.published_at,

  dateModified: post?.date_updated || post?.published_at,

  author: {
    "@type": "Organization",

    name: "GovtJobsNotice",
  },

  publisher: {
    "@type": "Organization",

    name: "GovtJobsNotice",
  },

  mainEntityOfPage: {
    "@type": "WebPage",

    "@id": `https://govtjobsnotice.com/${post?.slug}/`,
  },
};
---

<BaseLayout
  title={`${seoTitle} | GovtJobsNotice`}
  description={seoDescription}
  canonical={`/${post?.slug}/`}
  schema={schema}
  ogImage={post?.featured_image_url?.replace(
    "/upload/",
    "/upload/f_auto,q_auto/",
  )}
>
  <main class="post-page">
    <!-- PAGE INTRO -->

    <section class="page-intro-box">
      <Breadcrumbs
        items={[
          {
            label: post?.category
              ?.replaceAll("-", " ")
              ?.replace(/\b\w/g, (c: any) => c.toUpperCase()),

            href: `/${post?.category}/`,
          },

          {
            label: post?.title,
          },
        ]}
      />

      <h1 class="page-intro-title">
        {post?.title}
      </h1>

      {
        post?.published_at && (
          <div class="page-post-date">
            <strong>Last Updated:</strong>

            {formatDate(post?.published_at)}
          </div>
        )
      }

      {
        post?.intro_content && (
          <div class="editor-content" set:html={post?.intro_content} />
        )
      }
    </section>

    <!-- SOCIAL LINKS -->

    <SocialLinks />

    <!-- MAIN TITLE -->

    <section class="main-title-box">
      <h2 class="main-title">
        {postTitle}
      </h2>

      <div class="site-name">www.govtjobsnotice.com</div>

      <div class="main-status">
        {postTitle} : Overview
      </div>
    </section>

    <!-- FIRST ROW -->

    <div class="top-grid">
      <!-- IMPORTANT DATES -->

      {
        importantDates?.length > 0 && (
          <section class="post-box">
            <h2 class="pink-heading">Important Dates</h2>

            <div class="important-dates-wrapper">
              {importantDates.map((item: any) => (
                <div
                  class={`important-date-item ${
                    item?.ui?.highlight ? "active-date" : ""
                  }`}
                >
                  <span class="important-date-label">{item.label}</span>:
                  <span class="important-date-value">{item.display_text}</span>
                </div>
              ))}
            </div>
          </section>
        )
      }

      <!-- APPLICATION FEE -->
      {applicationFee && <SectionRenderer section={applicationFee} />}
    </div>

    <!-- SECOND ROW -->

    <div class="bottom-grid">
      <!-- AGE LIMIT -->

      {ageLimit && <SectionRenderer section={ageLimit} />}

      <!-- TOTAL POSTS -->

      <section class="post-box">
        <div class="orange-heading">Total Posts</div>

        <div class="total-post-number">
          {post.total_posts}
        </div>
      </section>
    </div>

    <!-- NORMAL SECTIONS -->
    {
      normalSections.map((section: any) => (
        <SectionRenderer section={section} />
      ))
    }
    {importantLinks && <SectionRenderer section={importantLinks} />}
    <!-- POST SUGGESTIONS -->

    <PostSuggestions currentSlug={post?.slug} category={post?.category} />

    <!-- FEATURED IMAGE -->

    {
      post?.featured_image_url && (
        <section class="bottom-featured-image-wrap">
          <img
            src={post.featured_image_url.replace(
              "/upload/",
              "/upload/f_auto,q_auto/",
            )}
            alt={`${post.title} - GovtJobsNotice`}
            class="bottom-featured-image"
            loading="lazy"
            decoding="async"
          />
        </section>
      )
    }

    <!-- DISCLAIMER -->

    <section class="disclaimer-box">
      <strong> Disclaimer : </strong>

      Information regarding any exam form, result, answer key, admit card and
      recruitment updates published on GovtJobsNotice.Com are provided only for
      immediate informational purposes. Candidates are advised to verify all
      details through the official website and official notification before
      applying. GovtJobsNotice is not responsible for any inadvertent errors.
    </section>
  </main>
</BaseLayout>

<style>
  .top-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin-top: 20px;
  }

  .bottom-grid {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 16px;
    margin-top: 16px;
    margin-bottom: 20px;
  }

  @media (max-width: 768px) {
    .top-grid,
    .bottom-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
