---
import BaseLayout from "../layouts/BaseLayout.astro";

import { getAllPosts, getPostBySlug } from "../lib/repositories/postRepository";

import Breadcrumbs from "../components/Breadcrumbs.astro";
import PostSuggestions from "../components/PostSuggestions.astro";
import SocialLinks from "../components/SocialLinks.astro";

export async function getStaticPaths() {
  const posts = await getAllPosts();

  return posts.map((post) => ({
    params: {
      slug: post.slug,
    },
  }));
}

const { slug } = Astro.params;

const post = await getPostBySlug(slug);

/* =========================================
   DATE FORMAT
========================================= */

const formatDate = (date: string) => {
  if (!date) return "";

  return new Date(date).toLocaleString("en-IN", {
    day: "numeric",
    month: "long",
    year: "numeric",
    hour: "numeric",
    minute: "2-digit",
    hour12: true,
  });
};

/* =========================================
   SAFE FAQ JSON PARSE
========================================= */

let faqData = [];

try {
  faqData =
    typeof post?.faq === "string"
      ? JSON.parse(post?.faq || "[]")
      : post?.faq || [];
} catch (error) {
  faqData = [];
}

/* =========================================
   SAFE IMPORTANT LINKS JSON PARSE
========================================= */

let importantLinksData = [];

try {
  importantLinksData =
    typeof post?.important_links === "string"
      ? JSON.parse(post?.important_links || "[]")
      : post?.important_links || [];
} catch (error) {
  importantLinksData = [];
}
---

<BaseLayout
  title={`${post?.title} | GovtJobsNotice`}
  description={post?.seo_description || post?.feed_title || post?.title}
  canonical={`https://govtjobsnotice.com/${post?.slug}/`}
  ogImage={post?.featured_image_url?.replace(
    "/upload/",
    "/upload/f_auto,q_auto/",
  )}
>
  <main class="post-page">
    <!-- PAGE INTRO -->

    <section class="page-intro-box">
      <Breadcrumbs
        items={[
          {
            label: post?.category
              ?.replaceAll("-", " ")
              ?.replace(/\b\w/g, (c: any) => c.toUpperCase()),

            href: `/${post?.category}/`,
          },

          {
            label: post?.title,
          },
        ]}
      />

      <h1 class="page-intro-title">
        {post?.title}
      </h1>

      {
        post?.latest_status_date && (
          <div class="page-post-date">
            <strong>Post Date:</strong>

            {formatDate(post?.latest_status_date)}
          </div>
        )
      }

      {
        post?.intro_content && (
          <div class="editor-content" set:html={post?.intro_content} />
        )
      }
    </section>

    <!-- SOCIAL LINKS -->

    <SocialLinks />

    <!-- MAIN TITLE -->

    <section class="main-title-box">
      <h2 class="main-title">
        {post?.feed_title || post?.title}
      </h2>

      <div class="site-name">www.GovtJobsNotice.Com</div>

      <div class="main-status">
        {post?.title} : Overview
      </div>
    </section>

    <!-- IMPORTANT DATES + APPLICATION FEE -->

    {
      (post?.important_dates || post?.application_fee) && (
        <div class="two-column-grid">
          {post?.important_dates && (
            <section class="post-box">
              <h2 class="pink-heading">Important Dates</h2>

              <div class="editor-content" set:html={post?.important_dates} />
            </section>
          )}

          {post?.application_fee && (
            <section class="post-box">
              <h2 class="pink-heading">Application Fee</h2>

              <div class="editor-content" set:html={post?.application_fee} />
            </section>
          )}
        </div>
      )
    }

    <!-- AGE LIMIT + TOTAL POSTS -->

    {
      (post?.age_limit || post?.total_posts) && (
        <div class="four-grid">
          {post?.age_limit && (
            <section class="age-box">
              <h2 class="green-heading">
                {post?.age_limit_title || "Age Limit"}
              </h2>

              <div class="editor-content" set:html={post?.age_limit} />
            </section>
          )}

          {post?.total_posts && (
            <section class="total-post-box">
              <h2 class="orange-heading">Total Posts</h2>

              <div class="total-post-number">{post?.total_posts}</div>
            </section>
          )}
        </div>
      )
    }

    <!-- VACANCY DETAILS -->

    {
      post?.vacancies_details && (
        <section class="post-box section-gap">
          <h2 class="blue-heading">{post?.title} : Vacancy Details</h2>

          <div class="editor-content" set:html={post?.vacancies_details} />
        </section>
      )
    }

    <!-- ELIGIBILITY -->

    {
      post?.eligibility && (
        <section class="post-box section-gap">
          <h2 class="blue-heading">{post?.title} : Eligibility Criteria</h2>

          <div class="editor-content" set:html={post?.eligibility} />
        </section>
      )
    }

    <!-- SALARY -->

    {
      post?.salary && (
        <section class="post-box section-gap">
          <h2 class="blue-heading">Salary Details</h2>

          <div class="editor-content" set:html={post?.salary} />
        </section>
      )
    }
    <!-- Selection Process -->

    {
      post?.selection_process && (
        <section class="post-box section-gap">
          <h2 class="blue-heading">Selection Process</h2>

          <div class="editor-content" set:html={post?.selection_process} />
        </section>
      )
    }

    <!-- HOW TO APPLY -->

    {
      post?.how_to_apply && (
        <section class="post-box section-gap">
          <h2 class="blue-heading">
            {post?.how_to_apply_title || "How To Apply"}
          </h2>

          <div class="editor-content" set:html={post?.how_to_apply} />
        </section>
      )
    }

    <!-- IMPORTANT LINKS -->

    {
      post?.important_links && (
        <section class="post-box section-gap">
          <h2 class="yellow-heading">Important Links</h2>

          {importantLinksData?.length > 0 ? (
            <div class="important-links-wrapper">
              {importantLinksData.map((item: any) => (
                <a
                  href={item.url}
                  target="_blank"
                  rel="nofollow noopener noreferrer"
                  class="important-link-item"
                >
                  <span class="important-link-label">{item.label}</span>

                  <span class="important-link-action">Click Here</span>
                </a>
              ))}
            </div>
          ) : (
            <div class="editor-content" set:html={post?.important_links} />
          )}
        </section>
      )
    }

    <!-- FAQ -->

    {
      post?.faq && (
        <section class="post-box section-gap">
          <h2 class="blue-heading">Frequently Asked Questions (FAQs)</h2>

          {faqData?.length > 0 ? (
            <div class="faq-wrapper">
              {faqData.map((item: any) => (
                <details class="faq-item">
                  <summary class="faq-question">{item.question}</summary>

                  <div class="faq-answer">{item.answer}</div>
                </details>
              ))}
            </div>
          ) : (
            <div class="editor-content" set:html={post?.faq} />
          )}
        </section>
      )
    }

    <!-- POST SUGGESTIONS -->

    <PostSuggestions currentSlug={post?.slug} category={post?.category} />

    <!-- FEATURED IMAGE -->

    {
      post?.featured_image_url && (
        <section class="bottom-featured-image-wrap">
          <img
            src={post.featured_image_url.replace(
              "/upload/",
              "/upload/f_auto,q_auto/",
            )}
            alt={post.title}
            class="bottom-featured-image"
            loading="lazy"
            decoding="async"
          />
        </section>
      )
    }

    <!-- DISCLAIMER -->

    <section class="disclaimer-box">
      <strong> Disclaimer : </strong>

      Information regarding any exam form, result, answer key, admit card and
      recruitment updates published on GovtJobsNotice.Com are provided only for
      immediate informational purposes. Candidates are advised to verify all
      details through the official website and official notification before
      applying. GovtJobsNotice is not responsible for any inadvertent errors.
    </section>
  </main>
</BaseLayout>
