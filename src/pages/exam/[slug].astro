---
import BaseLayout from "../../layouts/BaseLayout.astro";

import Breadcrumbs from "../../components/Breadcrumbs.astro";

import PostSuggestions from "../../components/PostSuggestions.astro";

import SocialLinks from "../../components/SocialLinks.astro";

import {
    getAllExams,
    getExamBySlug,
    getExamPosts,
} from "../../lib/repositories/examRepository";

import { buildExamMeta } from "../../lib/seo/buildExamMeta";

import { buildExamSchema } from "../../lib/seo/buildExamSchema";

/* =========================================
   STATIC PATHS
========================================= */

export async function getStaticPaths() {
    const exams = await getAllExams();

    return exams.map((exam) => ({
        params: {
            slug: exam.slug,
        },
    }));
}

/* =========================================
   PARAMS
========================================= */

const { slug } = Astro.params;

/* =========================================
   EXAM
========================================= */

const exam = await getExamBySlug(slug);

if (!exam) {
    return Astro.redirect("/404");
}

/* =========================================
   POSTS
========================================= */

const latestUpdates = await getExamPosts(exam.id, 12);

/* =========================================
   TOC FROM H2
========================================= */

const toc: {
    id: string;
    text: string;
}[] = [];

let contentHtml = exam.content || "";

contentHtml = contentHtml.replace(
    /<h2[^>]*>(.*?)<\/h2>/gi,
    (_match: string, title: string) => {
        const cleanTitle = title.replace(/<[^>]*>/g, "").trim();

        const id = cleanTitle
            .toLowerCase()
            .replace(/[^a-z0-9]+/g, "-")
            .replace(/^-|-$/g, "");

        toc.push({
            id,
            text: cleanTitle,
        });

        return `<h2 id="${id}" class="exam-content-heading">${title}</h2>`;
    },
);

/* =========================================
   SEO
========================================= */

const meta = buildExamMeta(exam);

const schema = buildExamSchema(exam);
---

<BaseLayout
    title={meta.title}
    description={meta.description}
    canonical={meta.canonical}
    keywords={meta.keywords}
    schema={schema}
>
    <article class="exam-page">
        <!-- HERO -->

        <section class="exam-hero">
            <Breadcrumbs
                items={[
                    {
                        label: "Exams",
                        href: "/exams",
                    },
                    {
                        label: exam.short_name + " " + exam.current_year || exam.title,
                    },
                ]}
            />

            <h1 class="exam-title">
                {exam.short_name} {exam.current_year}
            </h1>

            <div class="exam-meta-line">
                <span>
                    {exam.organization || "Government of India"}
                </span>

                <span class="exam-dot"> • </span>

                <span>
                    {(exam.category || "Government Exam").toUpperCase()}
                </span>

                <span class="exam-dot"> • </span>

                <span>
                    {exam.exam_level || "National"}
                </span>

                {
                    exam.official_website && (
                        <>
                            <span class="exam-dot"> • </span>

                            <a
                                href={exam.official_website}
                                target="_blank"
                                rel="nofollow noopener"
                            >
                                Official Website
                            </a>
                        </>
                    )
                }
            </div>

            <div class="exam-updated-line">
                Last Updated :

                {
                    latestUpdates?.[0]?.published_at
                        ? new Date(
                              latestUpdates[0].published_at,
                          ).toLocaleDateString("en-IN", {
                              day: "numeric",
                              month: "long",
                              year: "numeric",
                          })
                        : exam.date_updated
                          ? new Date(exam.date_updated).toLocaleDateString(
                                "en-IN",
                                {
                                    day: "numeric",
                                    month: "long",
                                    year: "numeric",
                                },
                            )
                          : "-"
                }
            </div>
        </section>

        <!-- MAIN GRID -->

        <div class="exam-layout">
            <!-- SIDEBAR -->

            <aside class="exam-sidebar">
                {
                    toc.length > 0 && (
                        <div class="exam-toc">
                            <div class="exam-toc-title">Table of Contents</div>

                            <ul class="exam-toc-list">
                                {toc.map((item) => (
                                    <li>
                                        <a href={`#${item.id}`}>{item.text}</a>
                                    </li>
                                ))}
                            </ul>
                        </div>
                    )
                }
            </aside>

            <!-- CONTENT -->

            <div class="exam-content">
                {
                    latestUpdates.length > 0 && (
                        <section class="exam-box">...</section>
                    )
                }

                <section class="exam-box">
                    <div class="editor-content" set:html={contentHtml} />
                </section>

                {
                    exam.featured_image && (
                        <section class="exam-box">
                            <img
                                src={exam.featured_image}
                                alt={exam.title}
                                class="exam-featured-image"
                                loading="lazy"
                            />
                        </section>
                    )
                }
            </div>
        </div>

        <!-- RELATED POSTS -->

        <PostSuggestions currentSlug="" category={exam.category} />

        <!-- SOCIAL LINKS -->

        <SocialLinks />
    </article>
</BaseLayout>
