---
import BaseLayout from "../../layouts/BaseLayout.astro";

import Breadcrumbs from "../../components/Breadcrumbs.astro";

import PostSuggestions from "../../components/PostSuggestions.astro";

import SocialLinks from "../../components/SocialLinks.astro";

import {
    getAllExams,
    getExamBySlug,
    getExamPosts,
} from "../../lib/repositories/examRepository";

import { buildExamSeo } from "../../lib/seo/buildExamSeo";

/* =========================================
   STATIC PATHS
========================================= */

export async function getStaticPaths() {
    const exams = await getAllExams();

    return exams.map((exam) => ({
        params: {
            slug: exam.slug,
        },
    }));
}

/* =========================================
   PARAMS
========================================= */

const { slug } = Astro.params;

/* =========================================
   EXAM
========================================= */

const exam = await getExamBySlug(slug);

if (!exam) {
    return Astro.redirect("/404");
}

/* =========================================
   POSTS
========================================= */

const latestUpdates = await getExamPosts(exam.id, 12);

/* =========================================
   TOC FROM H2
========================================= */

const toc: {
    id: string;
    text: string;
}[] = [];

let contentHtml = exam.content || "";

/* remove CKEditor table wrapper */

contentHtml = contentHtml.replace(/<figure class="table">/gi, "");

contentHtml = contentHtml.replace(/<\/figure>/gi, "");

/* clean table attributes */

contentHtml = contentHtml.replace(/<table[^>]*>/gi, "<table>");

/* add single wrapper */

contentHtml = contentHtml.replace(
    /<table>/gi,
    '<div class="table-scroll"><table>',
);

contentHtml = contentHtml.replace(/<\/table>/gi, "</table></div>");
contentHtml = contentHtml.replace(
    /<a([^>]*)>\[BUTTON\](.*?)<\/a>/gi,
    '<a$1 class="status-btn">$2</a>',
);
contentHtml = contentHtml.replace(
    /<h2[^>]*>(.*?)<\/h2>/gi,
    (_match: string, title: string) => {
        const cleanTitle = title.replace(/<[^>]*>/g, "").trim();

        const id = cleanTitle
            .toLowerCase()
            .replace(/[^a-z0-9]+/g, "-")
            .replace(/^-|-$/g, "");

        toc.push({
            id,
            text: cleanTitle,
        });

        return `<h2 id="${id}" class="exam-content-heading">${title}</h2>`;
    },
);
if (exam?.faqs?.length > 0) {
    toc.push({
        id: "frequently-asked-questions",
        text: "Frequently Asked Questions",
    });
}
/* =========================================
   SEO
========================================= */

const seo = buildExamSeo(exam);
---

<BaseLayout {...seo}>
    <article class="exam-page">
        <!-- HERO -->

        <section class="exam-hero">
            <Breadcrumbs
                items={[
                    {
                        label: "Exams",
                        href: "/exams",
                    },
                    {
                        label:
                            exam.short_name + " " + exam.current_year ||
                            exam.title,
                    },
                ]}
            />

            <h1 class="exam-title">
                {exam.short_name}
                {exam.current_year}
            </h1>

            <div class="exam-meta-line">
                <span>
                    {exam.organization || "Government of India"}
                </span>

                <span class="exam-dot"> • </span>

                <span>
                    {(exam.category || "Government Exam").toUpperCase()}
                </span>

                <span class="exam-dot"> • </span>

                <span>
                    {exam.exam_level || "National"}
                </span>

                {
                    exam.official_website && (
                        <>
                            <span class="exam-dot"> • </span>

                            <a
                                href={exam.official_website}
                                target="_blank"
                                rel="nofollow noopener"
                            >
                                Official Website
                            </a>
                        </>
                    )
                }
            </div>

            <div class="exam-updated-line">
                Last Updated :

                {
                    latestUpdates?.[0]?.published_at
                        ? new Date(
                              latestUpdates[0].published_at,
                          ).toLocaleDateString("en-IN", {
                              day: "numeric",
                              month: "long",
                              year: "numeric",
                          })
                        : exam.date_updated
                          ? new Date(exam.date_updated).toLocaleDateString(
                                "en-IN",
                                {
                                    day: "numeric",
                                    month: "long",
                                    year: "numeric",
                                },
                            )
                          : "-"
                }
            </div>
        </section>

        <!-- MAIN GRID -->

        <div class="exam-layout">
            <!-- SIDEBAR -->

            <aside class="exam-sidebar">
                {
                    toc.length > 0 && (
                        <div class="exam-toc">
                            <div class="exam-toc-title">Table of Contents</div>

                            <ul class="exam-toc-list">
                                {toc.map((item) => (
                                    <li>
                                        <a href={`#${item.id}`}>{item.text}</a>
                                    </li>
                                ))}
                            </ul>
                        </div>
                    )
                }
            </aside>

            <!-- CONTENT -->

            <div class="exam-content">
                {
                    latestUpdates.length > 0 && (
                        <section class="exam-box">...</section>
                    )
                }

                <section class="exam-box">
                    <div class="editor-content" set:html={contentHtml} />
                </section>

                {
                    exam.featured_image && (
                        <section class="exam-box">
                            <img
                                src={exam.featured_image}
                                alt={exam.title}
                                class="exam-featured-image"
                                loading="lazy"
                            />
                        </section>
                    )
                }
                {
                    exam?.faqs?.length > 0 && (
                        <section class="exam-box">
                            <h2
                                id="frequently-asked-questions"
                                class="exam-content-heading"
                                style="margin:0 0 20px;"
                            >
                                Frequently Asked Questions
                            </h2>

                            <div class="faq-list">
                                {exam.faqs.map((faq: any) => (
                                    <details class="faq-item">
                                        <summary class="faq-question">
                                            {faq.question}
                                        </summary>

                                        <div class="faq-answer">
                                            <p>{faq.answer}</p>
                                        </div>
                                    </details>
                                ))}
                            </div>
                        </section>
                    )
                }
                  <!-- RELATED POSTS -->

        <PostSuggestions
            currentSlug=""
            category={exam.category}
            showRelated={false}
        />
            </div>
        </div>

      

        <!-- SOCIAL LINKS -->

        <SocialLinks />
    </article>
</BaseLayout>
