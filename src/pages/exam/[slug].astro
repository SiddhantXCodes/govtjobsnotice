---
import BaseLayout from "../../layouts/BaseLayout.astro";

import Breadcrumbs from "../../components/Breadcrumbs.astro";

import PostSuggestions from "../../components/PostSuggestions.astro";

import SocialLinks from "../../components/SocialLinks.astro";

import { EXAM_LIFECYCLE_TEMPLATES } from "../../lib/examLifecycleTemplates";

import { EXAM_PAGE_SECTIONS } from "../../lib/examPageSections";

import {
    getAllExams,
    getExamBySlug,
    getExamPosts,
} from "../../lib/repositories/examRepository";

import { buildExamLifecycle } from "../../lib/repositories/examLifecycle";

import { buildExamMeta } from "../../lib/seo/buildExamMeta";

import { buildExamSchema } from "../../lib/seo/buildExamSchema";

/* =========================================
   STATIC PATHS
========================================= */

export async function getStaticPaths() {
    const exams = await getAllExams();

    return exams.map((exam) => ({
        params: {
            slug: exam.slug,
        },
    }));
}

/* =========================================
   PARAMS
========================================= */

const { slug } = Astro.params;

/* =========================================
   EXAM
========================================= */

const exam = await getExamBySlug(slug);

if (!exam) {
    return Astro.redirect("/404");
}

/* =========================================
   POSTS
========================================= */

const latestUpdates = await getExamPosts(exam.id, 12);

const lifecycle = buildExamLifecycle(latestUpdates);

/* =========================================
   SEO
========================================= */

const meta = buildExamMeta(exam);

const schema = buildExamSchema(exam);

/* =========================================
   SECTIONS
========================================= */

const sections = EXAM_PAGE_SECTIONS.filter((section) => {
    /* LIFECYCLE */

    if (section.type === "lifecycle") {
        return true;
    }

    /* CONTENT */

    return !!exam[section.field];
});
---

<BaseLayout
    title={meta.title}
    description={meta.description}
    canonical={meta.canonical}
    keywords={meta.keywords}
    schema={schema}
>
    <article class="exam-page">
        <!-- HERO -->

        <section class="exam-hero">
            <Breadcrumbs
                items={[
                    {
                        label: "Exams",
                        href: "/exams",
                    },
                    {
                        label: exam.short_name || exam.title,
                    },
                ]}
            />

            <h1 class="exam-title">
                {exam.title}
            </h1>

            <div class="exam-meta-line">
                <span>
                    {exam.organization || "Government of India"}
                </span>

                <span class="exam-dot"> • </span>

                <span>
                    {exam.category || "Government Exam"}
                </span>

                <span class="exam-dot"> • </span>

                <span>
                    {exam.level || "National Level"}
                </span>
            </div>

            <div class="exam-updated-line">
                Last Updated :

                {
                    exam.last_updated
                        ? new Date(exam.last_updated).toLocaleDateString(
                              "en-IN",
                              {
                                  day: "numeric",
                                  month: "long",
                                  year: "numeric",
                              },
                          )
                        : "-"
                }
            </div>
        </section>

        <!-- MAIN GRID -->

        <div class="exam-layout">
            <!-- SIDEBAR -->

            <aside class="exam-sidebar">
                <div class="exam-toc">
                    <div class="exam-toc-title">Table of Contents</div>

                    <ul class="exam-toc-list">
                        {
                            sections.map((section) => (
                                <li>
                                    <a href={`#${section.id}`}>
                                        {section.label}
                                    </a>
                                </li>
                            ))
                        }
                    </ul>
                </div>
            </aside>

            <!-- CONTENT -->

            <div class="exam-content">
                <!-- LATEST UPDATES -->

                {
                    latestUpdates.length > 0 && (
                        <section class="exam-box">
                            <h2 class="exam-box-heading">
                                {exam.short_name} {exam.year} Latest Updates
                            </h2>

                            <ul class="exam-update-list">
                                {latestUpdates.map((post) => (
                                    <li>
                                        <a href={`/${post.slug}/`}>
                                            {post.title}
                                        </a>
                                    </li>
                                ))}
                            </ul>
                        </section>
                    )
                }

                <!-- ALL SECTIONS -->

                {
                    sections.map((section) => {
                        /* =====================================
                         LIFECYCLE
                        ===================================== */
                        if (section.type === "lifecycle") {
                            const lifecycleItem = lifecycle[section.statusType];

                            if (!lifecycleItem) {
                                return null;
                            }

                            /* TEMPLATE */

                            let template = null;

                            /* =====================================
       ACTIVE
    ===================================== */

                            if (lifecycleItem.status === "active") {
                                template = EXAM_LIFECYCLE_TEMPLATES[
                                    section.statusType
                                ]?.active?.(exam, lifecycleItem.post);
                            } else if (lifecycleItem.status === "released") {
                                /* =====================================
       RELEASED
    ===================================== */
                                template =
                                    EXAM_LIFECYCLE_TEMPLATES[
                                        section.statusType
                                    ]?.released?.(exam);
                            } else {
                                /* =====================================
       UPCOMING
    ===================================== */
                                template =
                                    EXAM_LIFECYCLE_TEMPLATES[
                                        section.statusType
                                    ]?.upcoming?.(exam);
                            }

                            if (!template) {
                                return null;
                            }

                            return (
                                <section id={section.id} class="exam-box">
                                    <h2 class="exam-box-heading">
                                        {template.title}
                                    </h2>

                                    <div class="editor-content">
                                        <div set:html={template.content} />

                                        {lifecycleItem.status === "active" &&
                                            lifecycleItem.post &&
                                            template.buttonLabel && (
                                                <a
                                                    href={`/${lifecycleItem.post.slug}/`}
                                                    class="status-btn"
                                                >
                                                    {lifecycleItem.post
                                                        ?.title ||
                                                        template.buttonLabel}
                                                </a>
                                            )}
                                    </div>
                                </section>
                            );
                        }

                        /* =====================================
                                CONTENT
                                            ===================================== */

                        const content = exam[section.field];

                        if (!content) {
                            return null;
                        }

                        /* IMPORTANT DATES */

                        if (section.field === "important_dates") {
                            return (
                                <section id={section.id} class="exam-box">
                                    <h2 class="exam-box-heading">
                                        {exam.short_name} {exam.year}{" "}
                                        {section.label}
                                    </h2>

                                    <div class="exam-table-wrap">
                                        <table class="exam-table">
                                            <thead>
                                                <tr>
                                                    <th>Event</th>

                                                    <th>Date</th>
                                                </tr>
                                            </thead>

                                            <tbody>
                                                {content.map((item) => (
                                                    <tr>
                                                        <td>{item.event}</td>

                                                        <td>{item.date}</td>
                                                    </tr>
                                                ))}
                                            </tbody>
                                        </table>
                                    </div>
                                </section>
                            );
                        }

                        /* IMPORTANT LINKS */

                        if (section.field === "important_links") {
                            return (
                                <section id={section.id} class="exam-box">
                                    <h2 class="exam-box-heading">
                                        {exam.short_name} {exam.year}{" "}
                                        {section.label}
                                    </h2>

                                    <div class="exam-table-wrap">
                                        <table class="exam-table">
                                            <tbody>
                                                {content.map((item) => (
                                                    <tr>
                                                        <td>{item.label}</td>

                                                        <td>
                                                            <a
                                                                href={item.url}
                                                                target="_blank"
                                                                rel="noopener noreferrer"
                                                            >
                                                                Click Here
                                                            </a>
                                                        </td>
                                                    </tr>
                                                ))}
                                            </tbody>
                                        </table>
                                    </div>
                                </section>
                            );
                        }

                        /* NORMAL HTML */

                        return (
                            <section id={section.id} class="exam-box">
                                <h2 class="exam-box-heading">
                                    {exam.short_name} {exam.year}{" "}
                                    {section.label}
                                </h2>

                                <div
                                    class="editor-content"
                                    set:html={content}
                                />
                            </section>
                        );
                    })
                }
            </div>
        </div>

        <!-- RELATED -->

        <PostSuggestions currentSlug="" category="" />

        <SocialLinks />
    </article>
</BaseLayout>
