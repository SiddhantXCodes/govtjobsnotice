---
import BaseLayout from "../../layouts/BaseLayout.astro";

import Breadcrumbs from "../../components/Breadcrumbs.astro";

import PostSuggestions from "../../components/PostSuggestions.astro";

import SocialLinks from "../../components/SocialLinks.astro";

import { EXAM_LIFECYCLE_TEMPLATES } from "../../lib/examLifecycleTemplates";

import { EXAM_PAGE_SECTIONS } from "../../lib/examPageSections";
import SectionRenderer from "../../components/post/SectionRenderer.astro";
import {
    getAllExams,
    getExamBySlug,
    getExamPosts,
} from "../../lib/repositories/examRepository";

import { buildExamLifecycle } from "../../lib/repositories/examLifecycle";

import { buildExamMeta } from "../../lib/seo/buildExamMeta";

import { buildExamSchema } from "../../lib/seo/buildExamSchema";

/* =========================================
   STATIC PATHS
========================================= */

export async function getStaticPaths() {
    const exams = await getAllExams();

    return exams.map((exam) => ({
        params: {
            slug: exam.slug,
        },
    }));
}

/* =========================================
   PARAMS
========================================= */

const { slug } = Astro.params;

/* =========================================
   EXAM
========================================= */

const exam = await getExamBySlug(slug);

if (!exam) {
    return Astro.redirect("/404");
}

/* =========================================
   POSTS
========================================= */

const latestUpdates = await getExamPosts(exam.id, 12);

const lifecycle = buildExamLifecycle(latestUpdates);
/* =========================================
   ACTIVE RECRUITMENT
========================================= */

const activeRecruitment = latestUpdates.length > 0 ? latestUpdates[0] : null;

/* =========================================
   RESOLVE FIELD
========================================= */
function getRecruitmentSection(sectionId: string) {
    const sections = activeRecruitment?.sections;

    if (!Array.isArray(sections)) {
        return null;
    }

    return sections.find((item: any) => item?.id === sectionId);
}

function resolveField(section: any) {
    const field = section.field;

    if (activeRecruitment) {
        if (field === "important_dates") {
            return activeRecruitment?.important_dates;
        }

        if (field === "important_links") {
            return activeRecruitment?.important_links;
        }

        const sectionData = getRecruitmentSection(field);

        if (sectionData) {
            return sectionData;
        }
    }

    return exam?.[field];
}
/* =========================================
   SEO
========================================= */

const meta = buildExamMeta(exam);


/* =========================================
   SECTIONS
========================================= */

const sections = EXAM_PAGE_SECTIONS.filter((section) => {
    if (section.type === "lifecycle") {
        return true;
    }

    return !!resolveField(section);
});

const schema = {

  "@context":
    "https://schema.org",

  "@type":
    "CollectionPage",

  name:
    exam.title,

  description:
    meta.description,

  url:
    `https://govtjobsnotice.com/exam/${exam.slug}/`,

  publisher: {

    "@type":
      "Organization",

    name:
      "GovtJobsNotice"

  }

};
---

<BaseLayout
    title={meta.title}
    description={meta.description}
    canonical={meta.canonical}
    keywords={meta.keywords}
    schema={schema}
>
    <article class="exam-page">
        <!-- HERO -->

        <section class="exam-hero">
            <Breadcrumbs
                items={[
                    {
                        label: "Exams",
                        href: "/exams",
                    },
                    {
                        label: exam.short_name || exam.title,
                    },
                ]}
            />

            <h1 class="exam-title">
                {exam.title}
                {exam.year ? `${exam.year}` : ""}
            </h1>

            <div class="exam-meta-line">
                <span>
                    {exam.organization || "Government of India"}
                </span>

                <span class="exam-dot"> • </span>

                <span>
                    {exam.category || "Government Exam"}
                </span>

                <span class="exam-dot"> • </span>

                <span>
                    {exam.level || "National Level"}
                </span>
            </div>

            <div class="exam-updated-line">
                Last Updated :

                {
                    latestUpdates?.[0]?.published_at || exam.last_updated
                        ? new Date(
                              latestUpdates?.[0]?.published_at ||
                                  exam.last_updated,
                          ).toLocaleDateString("en-IN", {
                              day: "numeric",
                              month: "long",
                              year: "numeric",
                          })
                        : "-"
                }
            </div>
        </section>

        <!-- MAIN GRID -->

        <div class="exam-layout">
            <!-- SIDEBAR -->

            <aside class="exam-sidebar">
                <div class="exam-toc">
                    <div class="exam-toc-title">Table of Contents</div>

                    <ul class="exam-toc-list">
                        {
                            sections.map((section) => (
                                <li>
                                    <a href={`#${section.id}`}>
                                        {section.label}
                                    </a>
                                </li>
                            ))
                        }
                    </ul>
                </div>
            </aside>

            <!-- CONTENT -->

            <div class="exam-content">
                <!-- LATEST UPDATES -->

                {
                    latestUpdates.length > 0 && (
                        <section class="exam-box">
                            <h2 class="exam-box-heading">
                                <h2 class="exam-box-heading">
                                    Latest {exam.short_name} Updates
                                </h2>
                            </h2>

                            <ul class="exam-update-list">
                                {latestUpdates.map((post) => (
                                    <li>
                                        <a href={`/${post.slug}/`}>
                                            {post.feed_title || post.title}
                                        </a>
                                    </li>
                                ))}
                            </ul>
                        </section>
                    )
                }

                <!-- ALL SECTIONS -->

                {
                    sections.map((section) => {
                        /* =====================================
                         LIFECYCLE
                        ===================================== */
                        if (section.type === "lifecycle") {
                            const lifecycleItem =
                                lifecycle[(section as any).statusType];

                            if (!lifecycleItem) {
                                return null;
                            }

                            /* TEMPLATE */

                            let template = null;

                            /* =====================================
                                ACTIVE
                            ===================================== */
                            const statusType = (section as any).statusType;

                            const lifecycleTemplate = (
                                EXAM_LIFECYCLE_TEMPLATES as any
                            )[statusType];
                            if (lifecycleItem.status === "active") {
                                template = lifecycleTemplate?.active?.(
                                    exam,
                                    lifecycleItem.post,
                                );
                            } else if (lifecycleItem.status === "released") {
                                template = lifecycleTemplate?.released?.(exam);
                            } else {
                                template = lifecycleTemplate?.upcoming?.(exam);
                            }

                            if (!template) {
                                return null;
                            }

                            return (
                                <section id={section.id} class="exam-box">
                                    <h2 class="exam-box-heading">
                                        {template.title}
                                    </h2>

                                    <div class="editor-content">
                                        <div set:html={template.content} />

                                        {lifecycleItem.status === "active" &&
                                            lifecycleItem.post &&
                                            template.buttonLabel && (
                                                <a
                                                    href={`/${lifecycleItem.post.slug}/`}
                                                    class="status-btn"
                                                >
                                                    {lifecycleItem.post
                                                        ?.feed_title ||
                                                        template.buttonLabel}
                                                </a>
                                            )}
                                    </div>
                                </section>
                            );
                        }

                        /* =====================================
                                CONTENT
                        ===================================== */

                        const content = resolveField(section);

                        if (!content) {
                            return null;
                        }

                        /* IMPORTANT DATES */

                        if ((section as any).field === "important_dates") {
                            const dates = Array.isArray(content)
                                ? content
                                : Object.values(content || {});

                            return (
                                <section id={section.id} class="exam-box">
                                    <h2 class="exam-box-heading">
                                        {exam.short_name} {exam.year}{" "}
                                        {section.label}
                                    </h2>

                                    <div class="exam-table-wrap">
                                        <table class="exam-table">
                                            <thead>
                                                <tr>
                                                    <th>Event</th>
                                                    <th>Date</th>
                                                </tr>
                                            </thead>

                                            <tbody>
                                                {dates.map((item: any) => (
                                                    <tr>
                                                        <td>
                                                            {item.event ||
                                                                item.label ||
                                                                "-"}
                                                        </td>

                                                        <td>
                                                            {item.display_text ||
                                                                (item.date
                                                                    ? new Date(
                                                                          item.date,
                                                                      ).toLocaleDateString(
                                                                          "en-IN",
                                                                          {
                                                                              day: "numeric",
                                                                              month: "long",
                                                                              year: "numeric",
                                                                          },
                                                                      )
                                                                    : "-")}
                                                        </td>
                                                    </tr>
                                                ))}
                                            </tbody>
                                        </table>
                                    </div>
                                </section>
                            );
                        }

                        /* IMPORTANT LINKS */
                        if (
                            (section as any).field === "important_links" &&
                            typeof content === "object"
                        ) {
                            const normalizedSection = {
                                ...content,
                                title: section.label,
                            };

                            return (
                                <section id={section.id} class="exam-box">
                                    <SectionRenderer
                                        section={normalizedSection}
                                    />
                                </section>
                            );
                        }

                        /* POST SECTION */

                        if (typeof content === "object" && content?.type) {
                            const normalizedSection = {
                                ...content,
                                title: section.label,
                            };

                            return (
                                <section id={section.id} class="exam-box">
                                    <SectionRenderer
                                        section={normalizedSection}
                                    />
                                </section>
                            );
                        }

                        /* EXAM HTML */

                        return (
                            <section id={section.id} class="exam-box">
                                <h2 class="exam-box-heading">
                                    {exam.short_name} {exam.year}{" "}
                                    {section.label}
                                </h2>

                                <div
                                    class="editor-content"
                                    set:html={content}
                                />
                            </section>
                        );
                    })
                }
            </div>
        </div>

        <!-- RELATED -->

        <PostSuggestions currentSlug="" category="" />

        <SocialLinks />
    </article>
</BaseLayout>
