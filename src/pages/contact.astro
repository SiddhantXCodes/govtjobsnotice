---
import BaseLayout from "../layouts/BaseLayout.astro";
import "../styles/static-page.css";
---

<BaseLayout
  title="Contact Us | GovtJobsNotice"
  description="Contact GovtJobsNotice"
>

<main class="static-page">

  <section class="static-box">

    <h1 class="static-title">
      Contact Us
    </h1>

    <div class="static-content">

      <p>

        If you have any queries,
        corrections, suggestions,
        copyright concerns or feedback,
        feel free to contact us.

      </p>

      <h2>
        Email
      </h2>

      <p>

        <a
          href="mailto:support@govtjobsnotice.com"
          class="contact-email"
        >

          support@govtjobsnotice.com

        </a>

      </p>

      <h2>
        Response Time
      </h2>

      <p>

        We usually respond within
        24–48 working hours.

      </p>

    </div>

  </section>

</main>

</BaseLayout>