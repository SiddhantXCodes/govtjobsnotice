---
import BaseLayout
  from "../layouts/BaseLayout.astro";

import Breadcrumbs
  from "../components/Breadcrumbs.astro";

import {
  getFeaturedPosts,
  getPostsByCategory
} from "../lib/repositories/postRepository";

import {
  getClosingSoonPosts
} from "../lib/helpers/getClosingSoonPosts";

import "../styles/pages/last-date.css";
/* FETCH POSTS */

const latestJobs =
  await getPostsByCategory(
    "latest-jobs",
    100
  );

const featuredPosts =
  await getFeaturedPosts(50);

/* REMOVE DUPLICATES */

const allPosts = [
  ...new Map(
    [...latestJobs, ...featuredPosts]
      .map((post)=>[
        post.slug,
        post
      ])
  ).values()
];

/* GET DEADLINES */

const closingSoonPosts =
  getClosingSoonPosts(allPosts);

/* FILTER VALID POSTS */
const validPosts =
  closingSoonPosts.filter(
    (item) => {

      return Boolean(
        item?.post
          ?.important_dates
          ?.application_end
          ?.date
      );

    }
  );
---

<BaseLayout
  title="Application Closing Soon | GovtJobsNotice"
  description="Check latest government jobs and application forms closing soon with application last dates."
>

<main class="page-container">

  <!-- HEADER -->

  <section class="page-header common-box">

    <Breadcrumbs
      items={[
        {
          label:"Application Closing Soon"
        }
      ]}
    />

    <h1 class="page-title">

      Application Closing Soon

    </h1>

    <div class="page-count">

      Total Posts :
      {validPosts.length}

    </div>

    <p class="page-description">

      Check latest government job applications,
      online forms and recruitment notifications
      with upcoming application last dates for
      SSC, Railway, Banking, UPSC, Defence,
      PSU and State Government recruitments.

    </p>

  </section>

  <!-- TABLE -->

  <section class="table-wrap">

    <table class="common-table">

      <thead>

        <tr>

          <th>
            Post Name
          </th>

          <th>
            Last Date
          </th>

        </tr>

      </thead>

      <tbody>

        {
          validPosts.map((item:any)=>(

            <tr>
        <td>
          <a href={`/${item.post.slug}/`} class="table-link" >
            {item.post.title}
          </a>

          {
            item.diffDays >= 0 && (
              <span class="last-date-urgency">
                (
                  {
                    item.diffDays === 0
                      ? "Closing Today"
                      : `${item.diffDays} Days Left`
                  }
                )

              </span>

            )
          }

        </td>

              <!-- LAST DATE -->

              <td>
                  {
                    item.post
                      ?.important_dates
                      ?.application_end
                      ?.display_text || "-"
                  }

              </td>

            </tr>

          ))
        }

      </tbody>

    </table>

  </section>

  <!-- SEO -->

  <section class="seo-box common-box">

    <h2>

      Latest Govt Job Forms Closing Soon

    </h2>

    <p>

      GovtJobsNotice provides latest government
      job notifications and online forms with
      upcoming application last dates for SSC,
      Railway, Banking, UPSC, Defence, PSU and
      State Government jobs.

    </p>

    <p>

      Candidates should regularly check
      application last dates, eligibility,
      important notifications and official
      announcements before applying online.

    </p>

  </section>

</main>

</BaseLayout>