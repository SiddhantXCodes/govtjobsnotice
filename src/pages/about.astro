---
import BaseLayout from "../layouts/BaseLayout.astro";
import "../styles/static-page.css";
---

<BaseLayout
  title="About Us | GovtJobsNotice"
  description="About GovtJobsNotice"
>

<main class="static-page">

  <section class="static-box">

    <h1 class="static-title">
      About GovtJobsNotice
    </h1>

    <div class="static-content">

      <p>

        GovtJobsNotice is an educational and informational platform
        created to provide latest government job notifications,
        admit cards, results, answer keys, admissions,
        syllabus updates and recruitment information
        for candidates across India.

      </p>

      <p>

        Our goal is to simplify job information
        and help students access important recruitment
        updates quickly and easily.

      </p>

      <h2>
        What We Provide
      </h2>

      <ul>

        <li>
          Latest Government Job Notifications
        </li>

        <li>
          Admit Cards
        </li>

        <li>
          Results & Answer Keys
        </li>

        <li>
          Syllabus & Exam Information
        </li>

        <li>
          Admission Updates
        </li>

      </ul>

      <h2>
        Important Note
      </h2>

      <p>

        GovtJobsNotice is not a government website
        and is not affiliated with any government organization.
        Candidates are advised to verify all details
        from the official website before applying.

      </p>

    </div>

  </section>

</main>

</BaseLayout>