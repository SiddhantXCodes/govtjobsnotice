---
import BaseLayout from "../layouts/BaseLayout.astro";

import {
  getFeaturedPosts,
  getPostsByCategory,
} from "../lib/repositories/postRepository";
import { getPostsByTag } from "../lib/repositories/postRepository";
import SocialLinks from "../components/SocialLinks.astro";

/* SEO SCHEMA */

const schema = {
  "@context": "https://schema.org",

  "@type": "WebSite",

  name: "GovtJobsNotice",

  url: "https://govtjobsnotice.com",

  description:
    "Latest Government Job Notifications, Sarkari Result, Admit Cards, Results, Answer Keys, Admissions and Recruitment Updates in India.",

  potentialAction: {
    "@type": "SearchAction",

    target: "https://govtjobsnotice.com/search?q={search_term_string}",

    "query-input": "required name=search_term_string",
  },
};

/* FETCH POSTS */

const featuredPosts = await getFeaturedPosts(8);

const latestJobs = await getPostsByCategory("latest-jobs", 10);

const results = await getPostsByCategory("results", 10);

const admitCards = await getPostsByCategory("admit-card", 10);

const answerKeys = await getPostsByCategory("answer-key", 10);

const admissions = await getPostsByCategory("admission", 10);

const syllabus = await getPostsByCategory("syllabus", 10);

const technicalJobs = await getPostsByTag("tech", 10);
const psuJobs = await getPostsByTag("psu", 10);
/* HOME SECTIONS */

const sections = [
  {
    title: "Latest Govt Jobs",
    slug: "latest-jobs",
    type: "category",
    posts: latestJobs,
  },

  {
    title: "Sarkari Results",
    slug: "results",
    type: "category",
    posts: results,
  },

  {
    title: "Admit Card",
    slug: "admit-card",
    type: "category",
    posts: admitCards,
  },

  {
    title: "Answer Key",
    slug: "answer-key",
    type: "category",
    posts: answerKeys,
  },
  {
    title: "Technical Jobs",
    slug: "tech",
    type: "tag",
    posts: technicalJobs,
  },
  {
    title: "PSU Jobs",
    slug: "psu",
    type: "tag",
    posts: psuJobs,
  },
  {
    title: "Admission",
    slug: "admission",
    type: "category",
    posts: admissions,
  },

  {
    title: "Syllabus",
    slug: "syllabus",
    type: "category",
    posts: syllabus,
  },
];

/* FEATURED COLORS */

const colors = [
  "red",
  "orange",
  "purple",
  "green",
  "blue",
  "darkred",
  "darkgreen",
  "sky",
];
---

<BaseLayout
  title="Latest Govt Jobs 2026, Sarkari Result, Admit Card, Results | GovtJobsNotice"
  description="GovtJobsNotice provides latest government jobs, Sarkari Result, admit cards, results, answer keys, syllabus, admissions and recruitment notifications for SSC, Railway, Banking, UPSC, Police, Defence and State Government Jobs in India."
  canonical="https://govtjobsnotice.com"
  keywords="govt jobs, government jobs, latest govt jobs, sarkari result, govtjobsnotice, govt jobs notice, admit card, results, answer key, recruitment, railway jobs, SSC jobs, banking jobs, UPSC jobs, police jobs, defence jobs, online form, govt vacancy"
  schema={schema}
>
  <main class="home-page">
    <!-- HERO -->

    <section class="hero-section">
      <div class="hero-box">
        <h1 class="hero-heading">
          Latest Government Jobs, Sarkari Result, Admit Card & Recruitment
          Updates
        </h1>

        <div class="hero-top-line">
          Railway Jobs • SSC • UPSC • Banking • Police • Defence • Teaching •
          State Government Jobs
        </div>

        <p class="hero-description">
          Get fastest updates for latest government jobs, Sarkari Result, admit
          cards, answer keys, exam notifications, admissions, syllabus and
          recruitment updates across India.
        </p>

        <div class="hero-buttons">
          <SocialLinks />
        </div>
      </div>
    </section>

    <!-- FEATURED POSTS -->

    <section class="featured-grid">
      {
        featuredPosts.map((post, index) => (
          <a
            href={`/${post.slug}/`}
            class={`featured-card ${colors[index % colors.length]}`}
          >
            <h2 class="featured-title">
              {post.title} ({post.total_posts} Posts)
            </h2>
          </a>
        ))
      }
    </section>

    <!-- HOME SECTIONS -->

    <section class="home-sections">
      {
        sections.map((section) => (
          <section class="home-card">
            <div class="home-card-heading">
              <h2>{section.title}</h2>
            </div>

            <ul class="home-list">
              {section.posts.map((post) => (
                <li class="home-list-item">
                  <a href={`/${post.slug}/`} class="home-list-link">
                    {post.feed_title}
                  </a>
                </li>
              ))}
            </ul>

            <div class="view-more-wrap">
              <a
                href={
                  section.type === "tag"
                    ? `/tag/${section.slug}/`
                    : `/category/${section.slug}/`
                }
                class="view-more-btn"
              >
                View More →
              </a>
            </div>
          </section>
        ))
      }
    </section>

    <!-- SEO CONTENT BLOCK -->

    <section class="seo-content-section">
      <h2>Latest Sarkari Result and Government Job Notifications</h2>

      <p>
        GovtJobsNotice provides latest government job notifications, Sarkari
        Result updates, admit cards, answer keys, syllabus, admissions and
        recruitment information for SSC, Railway, UPSC, Banking, Police,
        Defence, Teaching and State Government Jobs.
      </p>

      <p>
        Candidates can check latest online forms, eligibility, important dates,
        exam patterns, selection process, results and recruitment notifications
        for all major government exams across India.
      </p>
    </section>
  </main>
</BaseLayout>
