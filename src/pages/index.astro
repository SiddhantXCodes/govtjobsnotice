---
import BaseLayout from "../layouts/BaseLayout.astro";

import {
  getFeaturedPosts,
  getPostsByCategory,
  getPostsByTag,
} from "../lib/repositories/postRepository";

import SocialLinks from "../components/SocialLinks.astro";

import {
  getClosingSoonPosts,
} from "../lib/helpers/getClosingSoonPosts";
import {
  getFeedTitle
} from "../lib/helpers/postHelpers";
/* =========================================
   SEO SCHEMA
========================================= */

const schema = [
  {
    "@context": "https://schema.org",

    "@type": "WebSite",

    name: "GovtJobsNotice",

    url: "https://govtjobsnotice.com",

    description:
      "Latest Government Job Notifications, Sarkari Result, Admit Cards, Results, Answer Keys, Admissions and Recruitment Updates in India.",
  },

  {
    "@context": "https://schema.org",

    "@type": "Organization",

    name: "GovtJobsNotice",

    url: "https://govtjobsnotice.com",

    logo: "https://govtjobsnotice.com/logo.png",

    sameAs: [
      "https://t.me/GovtJobs_Notice",
      "https://youtube.com/@govtjobsnotice",
      "https://instagram.com/govtjobsnotice",
      "https://linkedin.com/company/govtjobsnotice"
    ]
  }
];

/* =========================================
   FETCH POSTS
========================================= */

const featuredPosts =
  await getFeaturedPosts(8);

const latestJobs =
  await getPostsByCategory(
    "latest-jobs",
    10
  );

const results =
  await getPostsByCategory(
    "results",
    10
  );

const admitCards =
  await getPostsByCategory(
    "admit-card",
    10
  );

const answerKeys =
  await getPostsByCategory(
    "answer-key",
    10
  );

const admissions =
  await getPostsByCategory(
    "admission",
    10
  );

const syllabus =
  await getPostsByCategory(
    "syllabus",
    10
  );

const technicalJobs =
  await getPostsByTag(
    "tech",
    10
  );

const psuJobs =
  await getPostsByTag(
    "psu",
    10
  );

/* =========================================
   CLOSING SOON POSTS
========================================= */

const allPostsForDeadlines =
  [
    ...new Map(

      [
        ...latestJobs,
        ...featuredPosts,

      ].map((post) => [
        post.slug,
        post,
      ])

    ).values(),
  ];

const closingSoonPosts =
  getClosingSoonPosts(
    allPostsForDeadlines
  );

/* =========================================
   HOME SECTIONS
========================================= */

const sections = [

  {
    title: "Latest Govt Jobs",
    slug: "latest-jobs",
    type: "category",
    posts: latestJobs,
  },

  {
    title: "Sarkari Results",
    slug: "results",
    type: "category",
    posts: results,
  },

  {
    title: "Admit Card",
    slug: "admit-card",
    type: "category",
    posts: admitCards,
  },

  {
    title: "Answer Key",
    slug: "answer-key",
    type: "category",
    posts: answerKeys,
  },

  {
    title: "Technical Jobs",
    slug: "tech",
    type: "tag",
    posts: technicalJobs,
  },

  {
    title: "PSU Jobs",
    slug: "psu",
    type: "tag",
    posts: psuJobs,
  },

  {
    title: "Admission",
    slug: "admission",
    type: "category",
    posts: admissions,
  },

  {
    title: "Syllabus",
    slug: "syllabus",
    type: "category",
    posts: syllabus,
  },

];

/* =========================================
   FEATURED COLORS
========================================= */

const colors = [
  "red",
  "orange",
  "purple",
  "green",
  "blue",
  "darkred",
  "darkgreen",
  "sky",
];

---

<BaseLayout
  title="Latest Govt Jobs 2026, Sarkari Result, Admit Card, Results | GovtJobsNotice"
  description="GovtJobsNotice provides latest government jobs, Sarkari Result, admit cards, results, answer keys, syllabus, admissions and recruitment notifications for SSC, Railway, Banking, UPSC, Police, Defence and State Government Jobs in India."
  canonical="/"
  ogImage="https://govtjobsnotice.com/default-og.jpg"
  schema={schema}
>

  <main class="home-page">

    <!-- HERO -->

    <section class="hero-section">

      <div class="hero-box">

        <h1 class="hero-heading">
          Latest Govt Jobs,
          Sarkari Result &
          Admit Card Updates
        </h1>

        <div class="hero-top-line">
          Railway Jobs • SSC • UPSC •
          Banking • Police • Defence •
          Teaching • State Government Jobs
        </div>

        <p class="hero-description">
          Get fastest updates for latest
          government jobs, results,
          admit cards, answer keys and
          recruitment notifications
          across India.
        </p>

        <div class="hero-buttons">
          <SocialLinks />
        </div>

      </div>

    </section>

    <!-- APPLICATION CLOSING SOON -->

    {
      closingSoonPosts?.length > 0 && (
        <section class="closing-section">

          <div class="closing-header">
            Application Closing Soon
          </div>

          <div class="closing-columns">

            {
              closingSoonPosts
                .filter(Boolean)
                .slice(0, 9)
                .map((item: any) => (

                  <div class="closing-line">

                    <a
                      href={`/${item.post.slug}/`}
                      class="closing-link"
                    >

             • {getFeedTitle(item.post)}

                      <span class="closing-days">

                        {
                          item.diffDays === 0
                            ? " - Form Closes Today"
                            : ` - Only ${item.diffDays} Days Left`
                        }

                      </span>

                    </a>

                  </div>

                ))
            }

          </div>

          <div class="closing-view-all">

            <a href="/last-date/">
              View All →
            </a>

          </div>

        </section>
      )
    }

    <!-- FEATURED POSTS -->

    {
      featuredPosts?.length > 0 && (
        <section class="featured-grid">

          {
            featuredPosts.map(
              (post, index) => (

                <a
                  href={`/${post.slug}/`}
                  class={`featured-card ${
                    colors[
                      index % colors.length
                    ]
                  }`}
                >

                  <h2 class="featured-title">
                    {getFeedTitle(post)}
                  </h2>

                </a>

              )
            )
          }

        </section>
      )
    }

    <!-- HOME SECTIONS -->

    <section class="home-sections">

      {
        sections.map(
          (section) => (

            section?.posts?.length > 0 && (

              <section class="home-card">

                <div class="home-card-heading">

                  <h2>
                    {section.title}
                  </h2>

                </div>

                <ul class="home-list">

                  {
                    section.posts.map(
                      (post: any) => (

                        <li class="home-list-item">

                          <a
                            href={`/${post.slug}/`}
                            class="home-list-link"
                          >

                            {
                              getFeedTitle(post)
                            }

                          </a>

                        </li>

                      )
                    )
                  }

                </ul>

                <div class="view-more-wrap">

                  <a
                    href={
                      section.type === "tag"
                        ? `/tag/${section.slug}/`
                        : `/category/${section.slug}/`
                    }
                    class="view-more-btn"
                  >

                    View More →

                  </a>

                </div>

              </section>

            )

          )
        )
      }

    </section>

    <!-- SEO CONTENT -->

    <section class="seo-content-section">

      <h2>
        Latest Sarkari Result and
        Government Job Notifications
      </h2>

      <p>
        GovtJobsNotice provides latest
        government job notifications,
        Sarkari Result updates,
        admit cards, answer keys,
        syllabus, admissions and
        recruitment information for
        SSC, Railway, UPSC, Banking,
        Police, Defence, Teaching and
        State Government Jobs.
      </p>

      <p>
        Candidates can check latest
        online forms, eligibility,
        important dates, exam patterns,
        selection process, results and
        recruitment notifications
        for all major government exams
        across India.
      </p>

    </section>

  </main>

</BaseLayout>
