---
import { FOOTER_EXAMS }
from "../constants/footerExams";
---

<footer class="site-footer">

  <!-- EXAMS STRIP -->

  <section class="footer-exams-strip">

    <div class="container">

      <h2 class="footer-strip-heading">

        Popular Government Exams

      </h2>

      <div class="footer-exams-grid">

        {
          FOOTER_EXAMS.map((group) => (

            <div class="footer-exam-category">

              <h3 class="footer-category-title">

                {group.category}

              </h3>

              <div class="footer-exams-links">

                {
                  group.exams.map((exam) => (

                    <a
                      href={`/exam/${exam.slug}/`}
                      class="footer-exam-item"
                    >

                      {exam.name}

                    </a>

                  ))
                }

              </div>

            </div>

          ))
        }

      </div>

    </div>

  </section>

  <!-- MAIN FOOTER -->

  <div class="footer-main">

    <div class="container">

      <div class="footer-grid">

        <!-- BRAND -->

        <div class="footer-brand">

          <div class="footer-logo">

            <a href="/">

              GOVT JOBS NOTICE

            </a>

          </div>

          <p class="footer-description">

            Latest government jobs,
            Sarkari Result,
            admit cards,
            answer keys,
            syllabus and recruitment updates.

          </p>

        </div>

        <!-- QUICK LINKS -->

        <div class="footer-column">

          <h3>

            Quick Links

          </h3>

          <div class="footer-links">

            <a href="/">
              Home
            </a>

            <a href="/all-posts/">
              All Posts
            </a>

            <a href="/exams/">
              Exams
            </a>

            <a href="/category/latest-jobs">
              Latest Jobs
            </a>

            <a href="/category/results">
              Results
            </a>

          </div>

        </div>

        <!-- IMPORTANT -->

        <div class="footer-column">

          <h3>

            Important

          </h3>

          <div class="footer-links">

            <a href="/about">
              About Us
            </a>

            <a href="/contact">
              Contact
            </a>

            <a href="/privacy-policy">
              Privacy Policy
            </a>

            <a href="/disclaimer">
              Disclaimer
            </a>

          </div>

        </div>

        <!-- SOCIAL -->

        <div class="footer-column">

          <h3>

            Follow Us

          </h3>

          <div class="footer-links footer-social-links">

            <a
              href="https://t.me/GovtJobs_Notice"
              target="_blank"
              rel="noopener noreferrer"
            >

              Telegram

            </a>

            <a
              href="https://whatsapp.com/channel/0029Vb7JzZS1yT2AI8P1gt39"
              target="_blank"
              rel="noopener noreferrer"
            >

              WhatsApp

            </a>

            <a
              href="https://youtube.com/@govtjobs_notice"
              target="_blank"
              rel="noopener noreferrer"
            >

              YouTube

            </a>

            <a
              href="https://instagram.com/govtjobsnotice"
              target="_blank"
              rel="noopener noreferrer"
            >

              Instagram

            </a>

            <a
              href="https://linkedin.com/company/govtjobsnotice"
              target="_blank"
              rel="noopener noreferrer"
            >

              LinkedIn

            </a>

          </div>

        </div>

      </div>

      <!-- DISCLAIMER -->

      <div class="footer-disclaimer">

        GovtJobsNotice is not affiliated
        with any government organization.
        Verify details from official websites.

      </div>

      <!-- COPYRIGHT -->

      <div class="footer-bottom">

        © 2026 GovtJobsNotice.com

      </div>

    </div>

  </div>

</footer>