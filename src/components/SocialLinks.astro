---
const {
  showWhatsApp = true,
  showTelegram = true,
  showYoutube = true,
  showInstagram = true,
  showLinkedin = true,
} = Astro.props;

/* SOCIAL LINKS */

const socials = {
  telegram: "https://t.me/GovtJobs_Notice",

  whatsapp: "https://chat.whatsapp.com/yourlink",

  youtube: "https://youtube.com/@govtjobsnotice",

  instagram: "https://instagram.com/govtjobsnotice",

  linkedin: "https://linkedin.com/company/govtjobsnotice",
};

/* SOCIAL SCHEMA */

const socialSchema = {
  "@context": "https://schema.org",

  "@type": "Organization",

  name: "GovtJobsNotice",

  url: "https://govtjobsnotice.com",

  sameAs: [
    socials.telegram,
    socials.whatsapp,
    socials.youtube,
    socials.instagram,
    socials.linkedin,
  ],
};
---

<!-- SEO SCHEMA -->

<script
  type="application/ld+json"
  set:html={JSON.stringify(socialSchema)}
></script>

<!-- SOCIAL LINKS -->

<section
  class="social-links-section"
  aria-labelledby="social-links-heading"
>

  <h2
    id="social-links-heading"
    class="social-heading"
  >

    Join GovtJobsNotice on Social Media

  </h2>

  <p class="social-description">

    Get latest government jobs,
    Sarkari Result updates,
    admit cards, answer keys,
    admissions and recruitment notifications
    through our official social media channels.

  </p>

  <div class="social-links">

    {
      showWhatsApp && (

        <a
          href={socials.whatsapp}
          class="whatsapp-btn"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Join GovtJobsNotice WhatsApp Channel"
        >

          WhatsApp

        </a>

      )
    }

    {
      showTelegram && (

        <a
          href={socials.telegram}
          class="telegram-btn"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Join GovtJobsNotice Telegram Channel"
        >

          Telegram

        </a>

      )
    }

    {
      showYoutube && (

        <a
          href={socials.youtube}
          class="youtube-btn"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Visit GovtJobsNotice YouTube Channel"
        >

          YouTube

        </a>

      )
    }

    {
      showInstagram && (

        <a
          href={socials.instagram}
          class="instagram-btn"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Follow GovtJobsNotice on Instagram"
        >

          Instagram

        </a>

      )
    }

    {
      showLinkedin && (

        <a
          href={socials.linkedin}
          class="linkedin-btn"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Follow GovtJobsNotice on LinkedIn"
        >

          LinkedIn

        </a>

      )
    }

  </div>

</section>

