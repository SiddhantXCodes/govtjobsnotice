---
type BreadcrumbItem = {
  label: string;
  href?: string;
};

const {
  items = [] as BreadcrumbItem[]
} = Astro.props;

/* FORMAT LINKS */

function formatHref(href?: string){

  if(!href){
    return "";
  }

  const cleanHref =
    href
      .replace(/^\/+|\/+$/g, "")
      .toLowerCase();

  /* CATEGORY PAGES */

  const categoryPages = [
    "latest-jobs",
    "admit-card",
    "results",
    "answer-key",
    "syllabus",
    "admission"
  ];

  if(categoryPages.includes(cleanHref)){

    return `/category/${cleanHref}/`;

  }

  /* TAG PAGES */

  const tagPages = [
    "tech",
    "non-tech",
    "railway",
    "engineering",
    "psu",
    "bank",
    "defence",
    "teaching"
  ];

  if(tagPages.includes(cleanHref)){

    return `/tag/${cleanHref}/`;

  }

  /* NORMAL LINKS */

  return href.startsWith("/")
    ? href
    : `/${href}`;

}

/* SCHEMA */

const breadcrumbSchema = {
  "@context": "https://schema.org",

  "@type": "BreadcrumbList",

  itemListElement: [
    {
      "@type": "ListItem",

      position: 1,

      name: "Home",

      item: "https://govtjobsnotice.com",
    },

    ...items.map((item, index) => ({

      "@type": "ListItem",

      position: index + 2,

      name: item.label,

      item: item.href
        ? `https://govtjobsnotice.com${formatHref(item.href)}`
        : undefined,

    })),
  ],
};
---

<!-- SEO SCHEMA -->

<script
  type="application/ld+json"
  set:html={JSON.stringify(breadcrumbSchema)}
></script>

<!-- BREADCRUMBS -->

<nav
  class="breadcrumbs"
  aria-label="Breadcrumb Navigation"
>

  <a href="/">
    Home
  </a>

  {
    items.map((item: BreadcrumbItem) => (

      <>

        <span class="breadcrumb-separator">
          ›
        </span>

        {
          item.href ? (

            <a href={formatHref(item.href)}>

              {item.label}

            </a>

          ) : (

            <span
              class="breadcrumb-current"
              aria-current="page"
            >

              {item.label}

            </span>

          )
        }

      </>

    ))
  }

</nav>

